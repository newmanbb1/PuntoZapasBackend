// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Sucursal {
  id_sucursal       Int               @id @default(autoincrement())
  nombre            String?           @db.VarChar(45)
  direccion         String?           @db.VarChar(45)
  estado            String?           @db.VarChar(10)
  usuarios          Usuario[]
  gastos_operativos GastoOperativo[]
  inventarios       Inventario[]

  @@map("sucursal")
}

model Cliente {
  id_cliente      Int      @id @default(autoincrement())
  nombre_completo String?  @db.VarChar(45)
  telefono        String?  @db.VarChar(9)
  email           String?  @db.VarChar(25)
  nit_facturacion String?  @db.VarChar(45)
  pedidos         Pedido[]

  @@map("cliente")
}

model Categoria {
  id_categoria Int        @id @default(autoincrement())
  nombre       String?    @db.VarChar(25)
  productos    Producto[]

  @@map("categoria")
}

model Usuario {
  id_usuario    Int      @id @default(autoincrement())
  sucursal_id   Int
  nombre        String?  @db.VarChar(100)
  rol           String?  @db.VarChar(20)
  email         String?  @unique @db.VarChar(100)
  password_hash String?  @db.VarChar(255)
  sucursal      Sucursal @relation(fields: [sucursal_id], references: [id_sucursal], onDelete: Cascade)
  pedidos       Pedido[]

  @@map("usuario")
}

model GastoOperativo {
  id_gasto_operativo Int      @id @default(autoincrement())
  sucursal_id        Int
  concepto           String   @db.VarChar(20)
  monto              Decimal  @db.Decimal(10, 2)
  fecha              DateTime? @default(now()) @db.Timestamptz
  sucursal           Sucursal @relation(fields: [sucursal_id], references: [id_sucursal], onDelete: Cascade)

  @@map("gasto_operativo")
}

model Producto {
  id_producto       Int                @id @default(autoincrement())
  categoria_id      Int
  modelo            String?            @db.VarChar(25)
  marca             String?            @db.VarChar(45)
  costo_adquisicion Decimal            @db.Decimal(10, 2)
  precio_venta      Decimal            @db.Decimal(10, 2)
  descripcion       String?            @db.VarChar(100)
  categoria         Categoria          @relation(fields: [categoria_id], references: [id_categoria], onDelete: Cascade)
  variantes         VarianteProducto[]

  @@map("producto")
}

model VarianteProducto {
  id_variante_producto Int             @id @default(autoincrement())
  producto_id          Int
  talla                String?         @db.VarChar(2)
  color                String?         @db.VarChar(15)
  sku                  String?         @unique @db.VarChar(50)
  producto             Producto        @relation(fields: [producto_id], references: [id_producto], onDelete: Cascade)
  detalles_pedido      DetallePedido[]
  inventarios          Inventario[]

  @@map("variante_producto")
}

model Pedido {
  id_pedido  Int             @id @default(autoincrement())
  cliente_id Int
  usuario_id Int?
  fecha      DateTime?       @default(now()) @db.Timestamptz
  estado     String?         @db.VarChar(50)
  origen     String?         @db.VarChar(50)
  total      Decimal         @db.Decimal(10, 2)
  cliente    Cliente         @relation(fields: [cliente_id], references: [id_cliente], onDelete: Cascade)
  usuario    Usuario?        @relation(fields: [usuario_id], references: [id_usuario], onDelete: Restrict)
  pagos      Pago[]
  detalles   DetallePedido[]

  @@map("pedido")
}

model Pago {
  id_pago                 Int       @id @default(autoincrement())
  pedido_id               Int
  metodo                  String?   @db.VarChar(25)
  pasarela                String?   @db.VarChar(25)
  id_transaccion_pasarela String?   @db.VarChar(50)
  estado_pago             String?   @db.VarChar(25)
  comprobante_url         String?   @db.VarChar(255)
  fecha_pago              DateTime? @db.Timestamptz
  pedido                  Pedido    @relation(fields: [pedido_id], references: [id_pedido], onDelete: Cascade)

  @@map("pago")
}

model DetallePedido {
  id_detalle_pedido Int              @id @default(autoincrement())
  pedido_id         Int
  variante_id       Int
  cantidad          Int?
  precio_unitario   Decimal          @db.Decimal(10, 2)
  subtotal          Decimal          @db.Decimal(10, 2)
  pedido            Pedido           @relation(fields: [pedido_id], references: [id_pedido], onDelete: Cascade)
  variante          VarianteProducto @relation(fields: [variante_id], references: [id_variante_producto], onDelete: Cascade)

  @@map("detalle_pedido")
}

model Inventario {
  id_inventario Int              @id @default(autoincrement())
  variante_id   Int
  sucursal_id   Int
  cantidad      Int?
  nivel_minimo  Int?
  sucursal      Sucursal         @relation(fields: [sucursal_id], references: [id_sucursal], onDelete: Cascade)
  variante      VarianteProducto @relation(fields: [variante_id], references: [id_variante_producto], onDelete: Cascade)

  @@map("inventario")
}
